{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PaperQuay",
  "version": "0.1.0",
  "identifier": "com.paperquay.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PaperQuay",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "targets": "all",
    "windows": {
      "wix": {
        "bannerPath": "installer/banner.bmp",
        "dialogImagePath": "installer/dialog.bmp",
        "language": {
          "en-US": {
            "localePath": null
          },
          "zh-CN": {
            "localePath": "installer/zh-CN.wxl"
          }
        }
      }
    }
  }
}
