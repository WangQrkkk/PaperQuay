        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "PaperQuay combines a desktop paper library, a PDF reader, structured document parsing, linked navigation, translation, and AI-assisted reading into one environment. Its central idea is that academic reading benefits from structure. When a paper is represented as linked pages and blocks, the reader can move more easily between layout, text, translation, and explanation. "
                    }
                ]
            },
